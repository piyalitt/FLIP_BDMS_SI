    default_email_option  = "CONFIRM_WITH_CODE"
    email_subject         = "Password Reset Request – FLIP"
    # {####} placeholder: 6-character verification code for password reset
    email_message         = <<-EOT
      <!DOCTYPE html>
      <html>
      <head>
        <meta charset="utf-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
      </head>
      <body style="margin: 0; padding: 0; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Inter, 'Helvetica Neue', sans-serif; background-color: #f5f5f5;">
