                  </td>
                </tr>
                
                <!-- Footer -->
                <tr>
                  <td style="background-color: #f9f9f9; padding: 24px 30px; border-top: 1px solid #eeeeee; text-align: center;">
                    <p style="margin: 0 0 8px 0; color: #9452A8; font-size: 13px; font-weight: 600;">The FLIP Team</p>
