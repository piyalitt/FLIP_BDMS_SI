                    <p style="margin: 8px 0 0 0; color: rgba(255,255,255,0.9); font-size: 14px; font-weight: 500;">Security & Account Management</p>
                  </td>
                </tr>
                
                <!-- Content section -->
                <tr>
                  <td style="padding: 40px 30px;">
                    <!-- Alert message -->
                    <p style="margin: 0 0 24px 0; color: #301A37; font-size: 16px; line-height: 1.5;">Hello,</p>
                    
                    <!-- Password reset message -->
                    <p style="margin: 0 0 24px 0; color: #434757; font-size: 16px; line-height: 1.6;">We received a request to reset your password for your <strong>FLIP</strong> (Federated Learning and Interoperability Platform) account.</p>
                    
                    <!-- Verification code section -->
                    <div style="background-color: #F7F3F9; border-left: 4px solid #9452A8; padding: 24px; margin: 24px 0; border-radius: 4px; text-align: center;">
                      <p style="margin: 0 0 16px 0; color: #61366e; font-size: 14px; font-weight: 600; text-transform: uppercase; letter-spacing: 1px;">Your verification code:</p>
                      <p style="margin: 0; color: #301A37; font-family: 'Monaco', 'Courier New', monospace; font-size: 32px; letter-spacing: 4px; font-weight: 700; word-spacing: 8px;">{####}</p>
                      <p style="margin: 12px 0 0 0; color: #9452A8; font-size: 13px;">Valid for 24 hours</p>
                    </div>
                    
                    <!-- Security notice -->
                    <div style="background-color: #FEF3F2; border-left: 4px solid #E51170; padding: 16px; margin: 24px 0; border-radius: 4px;">
                      <p style="margin: 0; color: #BF360C; font-size: 14px; line-height: 1.5;"><strong>⚠️ Security Tip:</strong> If you did not request this password reset, your account may be at risk. Please contact support immediately.</p>
                    </div>
                    
