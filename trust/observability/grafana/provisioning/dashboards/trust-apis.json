{
  "uid": "trust-apis-overview",
  "title": "Trust APIs",
  "tags": ["trust", "loki", "observability"],
  "timezone": "browser",
  "refresh": "10s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "api",
        "type": "custom",
        "label": "API",
        "current": {
          "text": "All",
          "value": "$__all"
        },
        "options": [
          { "text": "All", "value": "$__all", "selected": true },
          { "text": "trust-api", "value": "trust-api", "selected": false },
          { "text": "data-access-api", "value": "data-access-api", "selected": false },
          { "text": "imaging-api", "value": "imaging-api", "selected": false }
        ],
        "query": "trust-api,data-access-api,imaging-api",
        "allValue": "trust-api|data-access-api|imaging-api",
        "includeAll": true,
        "multi": false
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Requests / sec",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum(count_over_time({api=~\"$api\"} | json | event = `request.completed` [$__auto]))",
          "legendFormat": "req/s",
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["mean"] }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 100 }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "title": "Errors",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum(count_over_time({level=\"ERROR\", api=~\"$api\"} [$__auto]))",
          "legendFormat": "errors",
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["sum"] }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          },
          "noValue": "0"
        }
      }
    },
    {
      "id": 3,
      "title": "p95 Duration (ms)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "quantile_over_time(0.95, {api=~\"$api\"} | json | event = `request.completed` | unwrap duration_ms [$__auto]) by (api)",
          "legendFormat": "{{api}}",
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 500 },
              { "color": "red", "value": 2000 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Active APIs",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "count(sum by (api) (count_over_time({api=~\"trust-api|data-access-api|imaging-api\"} [$__auto])))",
          "legendFormat": "apis",
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 2 },
              { "color": "green", "value": 3 }
            ]
          },
          "noValue": "0"
        }
      }
    },
    {
      "id": 5,
      "title": "Request Rate by API",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum by (api) (count_over_time({api=~\"$api\"} | json | event = `request.completed` [$__auto]))",
          "legendFormat": "{{api}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 15,
            "pointSize": 5,
            "lineWidth": 2
          }
        }
      }
    },
    {
      "id": 6,
      "title": "Error Rate by API",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum by (api) (count_over_time({level=\"ERROR\", api=~\"$api\"} [$__auto]))",
          "legendFormat": "{{api}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 15,
            "pointSize": 5,
            "lineWidth": 2
          },
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "id": 7,
      "title": "p95 Request Duration by API",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "quantile_over_time(0.95, {api=~\"$api\"} | json | event = `request.completed` | unwrap duration_ms [$__auto]) by (api)",
          "legendFormat": "{{api}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 15,
            "pointSize": 5,
            "lineWidth": 2
          }
        }
      }
    },
    {
      "id": 8,
      "title": "Status Codes",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum by (status_code) (count_over_time({api=~\"$api\"} | json | event = `request.completed` | status_code != `` [$__auto]))",
          "legendFormat": "{{status_code}}",
          "refId": "A"
        }
      ],
      "options": {
        "stacking": "none",
        "barWidth": 0.8
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "id": 9,
      "title": "Slowest Requests",
      "type": "table",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 20 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{api=~\"$api\"} | json | event = `request.completed` | line_format `{{.api}} {{.method}} {{.path}} {{.status_code}} {{.duration_ms}}ms`",
          "refId": "A"
        }
      ],
      "options": {
        "sortBy": [{ "displayName": "duration_ms", "desc": true }]
      },
      "transformations": [
        {
          "id": "extractFields",
          "options": {
            "source": "labels",
            "format": "auto"
          }
        }
      ]
    },
    {
      "id": 10,
      "title": "Recent Errors",
      "type": "logs",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 28 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{level=\"ERROR\", api=~\"$api\"}",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": true,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      }
    },
    {
      "id": 11,
      "title": "All Logs",
      "type": "logs",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 36 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{api=~\"$api\"}",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": true,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      }
    }
  ],
  "schemaVersion": 39,
  "version": 1
}
