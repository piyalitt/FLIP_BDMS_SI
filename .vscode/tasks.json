{
    "version": "2.0.0",
    "inputs": [
        {
            "id": "serviceSelection",
            "description": "Select a service to debug",
            "type": "pickString",
            "options": [
                {
                    "label": "Central Hub API (flip-api)",
                    "value": "flip-api"
                },
                {
                    "label": "Federated Learning API (fl-api)",
                    "value": "fl-api"
                },
                {
                    "label": "Trust API (trust-api)",
                    "value": "trust-api"
                },
                {
                    "label": "Imaging API (imaging-api)",
                    "value": "imaging-api"
                },
                {
                    "label": "Data Access API (data-access-api)",
                    "value": "data-access-api"
                }
            ]
        }
    ],
    "tasks": [
        {
            "label": "debug-flip-api",
            "type": "shell",
            "command": "make",
            "args": [
                "debug",
                "SERVICE=flip-api"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
        },
        {
            "label": "debug-off-flip-api",
            "type": "shell",
            "command": "make",
            "args": [
                "debug-off",
                "SERVICE=flip-api"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "presentation": {
                "echo": true,
                "reveal": "silent",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": false,
                "clear": false
            },
        },
        {
            "label": "debug-service-interactive",
            "type": "shell",
            "command": "make",
            "args": [
                "debug",
                "SERVICE=${input:serviceSelection}"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
        },
        {
            "label": "debug-off-service-interactive",
            "type": "shell",
            "command": "make",
            "args": [
                "debug-off",
                "SERVICE=${input:serviceSelection}"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
