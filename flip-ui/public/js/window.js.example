// EXAMPLE FILE — for reference only.
// The real `public/js/window.js` is generated by `scripts/generate-window-js.sh`
// from environment variables. That file is gitignored and never hand-edited.
//
// In local dev, it's generated automatically by the `predev` npm hook before
// `vite dev` starts, using the VITE_* env vars passed by docker-compose.
//
// In stag/prod, it's generated by `make deploy-ui` (in deploy/providers/AWS/)
// using the env vars from .env.stag / .env.production, and uploaded to S3
// alongside the built bundle.
//
// See .env.development.example for the env vars involved.

window.AWS_BASE_URL            = "https://<host>/api";
window.AWS_USER_POOL_ID        = "<region>_<pool-id>";
window.AWS_CLIENT_ID           = "<app-client-id>";
window.AWS_REGION              = "eu-west-2";
window.BLACKLISTED_MODEL_FILES = "";
window.RELEASE_VERSION         = "";
