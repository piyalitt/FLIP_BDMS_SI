        "lodash": "^4.18.1",
        "lodash-es": "^4.18.1",
        "follow-redirects": ">=1.15.12"
    },
    "babel": {
        "presets": [
            [
                "@babel/preset-env",
                {
                    "targets": {
                        "node": "current"
                    }
                }
            ]
        ]
    }
