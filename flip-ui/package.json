{
    "name": "flip-ui",
    "version": "0.0.7",
    "engines": {
        "node": "^20.19.0 || >=22.12.0"
    },
    "scripts": {
        "generate-window-js": "sh scripts/generate-window-js.sh > public/js/window.js",
        "predev": "npm run generate-window-js",
        "dev": "vite --host 0.0.0.0 --port 443 --mode development",
        "prebuild": "npm run generate-window-js",
        "build": "vue-tsc --noEmit && vite build",
        "prebuild:deploy": "npm run generate-window-js",
        "build:deploy": "vite build",
        "serve": "vite preview",
        "test:unit": "vitest run --silent --coverage",
        "lint": "npx eslint ./src/**/*.vue ./src/**/*.ts",
        "prepare": "husky install",
        "test:unit:update": "vitest run -u --silent --coverage",
        "test:unit:watch": "vitest watch --silent",
        "prestart-test": "npm run generate-window-js",
        "start-test": "vite --host 127.0.0.1 --port 443 --mode development",
        "test:ui": "cypress run --browser chrome",
        "pretest:start": "npm run generate-window-js",
        "test:start": "vite --port 4173 --mode development",
        "test:ci": "start-server-and-test test:start http-get://localhost:4173 test:ui"
    },
    "dependencies": {
        "echarts": "^5.2.2",
        "husky": "^9.1.7",
        "vue": "^3.2.16",
        "vue-router": "^4.0.11"
    },
    "devDependencies": {
        "@babel/node": "^7.8.7",
        "@babel/preset-env": "^7.14.7",
        "@cypress/vite-dev-server": "^3.0.0",
        "@cypress/vue": "^3.0.5",
        "@headlessui/vue": "^1.7.0",
        "@heroicons/vue": "^1.0.4",
        "@iconify/json": "^1.1.413",
        "@pinia/testing": "^0.1.3",
        "@popperjs/core": "^2.10.2",
        "@tailwindcss/forms": "^0.5.2",
        "@tailwindcss/typography": "^0.5.4",
        "@types/jest": "^29.5.11",
        "@types/lucene": "^2.1.3",
        "@types/mime": "^2.0.3",
        "@types/node": "^20.10.4",
        "@types/underscore": "^1.11.4",
        "@types/uuid": "^8.3.1",
        "@typescript-eslint/eslint-plugin": "^8.57.2",
        "@typescript-eslint/parser": "^8.57.2",
        "@vitejs/plugin-vue": "^6.0.5",
        "@vitest/coverage-v8": "^4.1.2",
        "@vue/compiler-sfc": "^3.2.37",
        "@vue/eslint-config-typescript": "^14.7.0",
        "@vue/test-utils": "^2.0.0",
        "@vueuse/components": "^9.2.0",
        "@vueuse/core": "^8.7.5",
        "autoprefixer": "^10.4.7",
        "aws-amplify": "^6.15.3",
        "axios": "^1.15.0",
        "c8": "^11.0.0",
        "codemirror-editor-vue3": "^2.1.7",
        "cypress": "^14.5.2",
        "cypress-file-upload": "^5.0.8",
        "cypress-localstorage-commands": "^2.2.0",
        "date-fns": "^2.25.0",
        "dotenv": "^16.0.3",
        "eslint": "^10.1.0",
        "eslint-plugin-simple-import-sort": "^10.0.0",
        "eslint-plugin-vue": "^10.8.0",
        "jsdom": "^29.0.1",
        "lucene": "^2.1.1",
        "mime": "^2.5.2",
        "miragejs": "^0.1.42",
        "mitt": "^3.0.0",
        "pinia": "^2.1.7",
        "postcss": "^8.4.5",
        "start-server-and-test": "^2.0.12",
        "swrv": "^1.0.4",
        "tailwindcss": "^3.1.8",
        "ts-jest": "^29.1.2",
        "ts-node": "^10.9.2",
        "typescript": "^5.3.3",
        "underscore": "^1.13.4",
        "unplugin-icons": "^0.14.3",
        "unplugin-vue-components": "^28.8.0",
        "uuid": "^8.3.2",
        "vee-validate": "^4.5.8",
        "vite": "^8.0.9",
        "vite-plugin-icons": "^0.2.4",
        "vite-plugin-pages": "^0.33.3",
        "vite-plugin-progress": "^0.0.7",
        "vite-plugin-vue-inspector": "^5.4.0",
        "vite-plugin-vue-layouts-next": "^2.1.0",
        "vite-svg-loader": "^5.1.0",
        "vitest": "^4.1.2",
        "vue-click": "^2.1.7",
        "vue-eslint-parser": "^10.0.0",
        "vue-router-mock": "1.0.0",
        "vue-tippy": "^6.3.1",
        "vue-tsc": "^3.0.3",
        "vue3-highlightjs": "^1.0.5",
