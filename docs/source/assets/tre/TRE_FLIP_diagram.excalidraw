      "isDeleted": true,
      "boundElements": [],
      "updated": 1776160892683,
      "link": null,
      "locked": false,
      "text": "Stage 1 — Data Preparation (pre-federation)",
      "fontSize": 15.38795824849706,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Stage 1 — Data Preparation (pre-federation)",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "509ZICvO5kRixqp4rVcH2",
      "type": "text",
      "x": 260.8842740314149,
      "y": 1332.7775781185567,
      "width": 432.09212990290587,
      "height": 46.16387474549118,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bDT",
      "roundness": null,
      "seed": 204131835,
      "version": 475,
      "versionNonce": 938981653,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1776160892683,
      "link": null,
      "locked": false,
      "text": "Cohort discovery happens offline during initial discussions\nabout a new FLIP project, defining the target population and\ndata requirements.",
      "fontSize": 12.310366598797648,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Cohort discovery happens offline during initial discussions about a new FLIP project, defining the target population and data requirements.",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "He0xzCejmsH6O-mdVg2_3",
      "type": "text",
      "x": 261.2553148620749,
      "y": 1391.623827756495,
      "width": 431.9587156843235,
      "height": 46.16387474549118,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bDU",
      "roundness": null,
      "seed": 1664439963,
      "version": 498,
      "versionNonce": 793497275,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1776160892683,
      "link": null,
      "locked": false,
      "text": "Once approved by the Data Access Committee, Trust data is\ningested into the TRE through the TRE SOP, including de-\nidentification, defacing, etc.",
      "fontSize": 12.310366598797648,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Once approved by the Data Access Committee, Trust data is ingested into the TRE through the TRE SOP, including de-identification, defacing, etc.",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "x9TDz_7wvhCVEeJYsS2LS",
      "type": "text",
      "x": 260.35464451345484,
      "y": 1464.8927189478925,
      "width": 346.99845850360873,
      "height": 19.234947810621325,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bDV",
      "roundness": null,
      "seed": 1428540219,
      "version": 457,
      "versionNonce": 388615797,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1776160892683,
      "link": null,
      "locked": false,
      "text": "Stage 2 — Federated Learning / Evaluation",
      "fontSize": 15.387958248497062,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Stage 2 — Federated Learning / Evaluation",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "Bqe6clm8KzLgVX4iGrvT3",
      "type": "text",
      "x": 258.9437867871457,
      "y": 1503.0849066927356,
      "width": 417.8092776674023,
      "height": 30.77591649699412,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bDW",
      "roundness": null,
      "seed": 1717480411,
      "version": 494,
      "versionNonce": 603471707,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1776160892683,
      "link": null,
      "locked": false,
      "text": "FLIP users run cohort queries against the TRE OMOP database\nto select the relevant subset of pre-populated data.",
      "fontSize": 12.310366598797648,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "FLIP users run cohort queries against the TRE OMOP database to select the relevant subset of pre-populated data.",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "dEJMjAKAdmUwg83S-hu5b",
      "type": "text",
      "x": 260.2152808440785,
      "y": 1551.1348721612085,
      "width": 447.84116301831943,
      "height": 30.77591649699412,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bDX",
      "roundness": null,
      "seed": 1794275451,
      "version": 543,
      "versionNonce": 1714567125,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1776160892683,
      "link": null,
      "locked": false,
      "text": "XNAT (in TRE) pulls the corresponding imaging data into a\ndedicated project where images can be enriched.",
      "fontSize": 12.310366598797648,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "XNAT (in TRE) pulls the corresponding imaging data into a dedicated project where images can be enriched.",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "5m_1bUSfLsW0WOs_QQm2e",
      "type": "text",
      "x": 261.541488045285,
      "y": 1596.3048428244147,
      "width": 375.02134222635186,
      "height": 46.16387474549118,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bDY",
      "roundness": null,
      "seed": 279163163,
      "version": 605,
      "versionNonce": 1997380603,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1776160892683,
      "link": null,
      "locked": false,
      "text": "FLIP users submit AI model training/inference jobs that\nuse GPU resources. Only aggregated cohort stats and\naggregated model weights leave the TRE.",
      "fontSize": 12.310366598797648,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "FLIP users submit AI model training/inference jobs that use GPU resources. Only aggregated cohort stats and aggregated model weights leave the TRE.",
      "autoResize": false,
      "lineHeight": 1.25
    },
