      "boundElements": [],
      "updated": 1776160868478,
      "link": null,
      "locked": false,
      "text": "FLIP users submit AI model training/inference jobs\nthat use GPU resources. Only aggregated cohort\nstats and aggregated model weights leave the TRE.",
      "fontSize": 28,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "FLIP users submit AI model training/inference jobs that use GPU resources. Only aggregated cohort stats and aggregated model weights leave the TRE.",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "jR9j5OOLN5iafo2MhymRA",
      "type": "text",
      "x": -138.9122478896699,
      "y": 84.85337505455695,
      "width": 363.73699951171875,
      "height": 19.234947810621325,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bBp",
      "roundness": null,
      "seed": 2118120909,
      "version": 314,
      "versionNonce": 741113685,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1776160868478,
      "link": null,
      "locked": false,
      "text": "Stage 1 — Data Preparation (pre-federation)",
      "fontSize": 15.38795824849706,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Stage 1 — Data Preparation (pre-federation)",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "WW-SDWM6GCOnk9Pk39CC2",
      "type": "text",
      "x": -137.78429371981525,
      "y": 117.50179803347496,
      "width": 432.09212990290587,
      "height": 46.16387474549118,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bBq",
      "roundness": null,
      "seed": 2117917059,
      "version": 471,
      "versionNonce": 1516080251,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1776160868478,
      "link": null,
      "locked": false,
      "text": "Cohort discovery happens offline during initial discussions\nabout a new FLIP project, defining the target population and\ndata requirements.",
      "fontSize": 12.310366598797648,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Cohort discovery happens offline during initial discussions about a new FLIP project, defining the target population and data requirements.",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "qoYYHYxIjriO6mmqYGbsW",
      "type": "text",
      "x": -137.41325288915527,
      "y": 176.34804767141318,
      "width": 431.9587156843235,
      "height": 46.16387474549118,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bBr",
      "roundness": null,
      "seed": 867808301,
      "version": 494,
      "versionNonce": 762039477,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1776160868478,
      "link": null,
      "locked": false,
      "text": "Once approved by the Data Access Committee, Trust data is\ningested into the TRE through the TRE SOP, including de-\nidentification, defacing, etc.",
      "fontSize": 12.310366598797648,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Once approved by the Data Access Committee, Trust data is ingested into the TRE through the TRE SOP, including de-identification, defacing, etc.",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "wur3vwwki1yOUa1-8itQ3",
      "type": "text",
      "x": -138.31392323777533,
      "y": 249.61693886281077,
      "width": 346.99845850360873,
      "height": 19.234947810621325,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bBs",
      "roundness": null,
      "seed": 1158459683,
      "version": 453,
      "versionNonce": 160187675,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1776160868478,
      "link": null,
      "locked": false,
      "text": "Stage 2 — Federated Learning / Evaluation",
      "fontSize": 15.387958248497062,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Stage 2 — Federated Learning / Evaluation",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "m542ykZw7sHab1SHyxdcT",
      "type": "text",
      "x": -139.72478096408446,
      "y": 287.8091266076538,
      "width": 417.8092776674023,
      "height": 30.77591649699412,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bBt",
      "roundness": null,
      "seed": 1680647821,
      "version": 490,
      "versionNonce": 1478127125,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1776160868478,
      "link": null,
      "locked": false,
      "text": "FLIP users run cohort queries against the TRE OMOP database\nto select the relevant subset of pre-populated data.",
      "fontSize": 12.310366598797648,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "FLIP users run cohort queries against the TRE OMOP database to select the relevant subset of pre-populated data.",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "wztcgVYGOLflJpKxbq94R",
      "type": "text",
      "x": -138.45328690715166,
      "y": 335.8590920761267,
      "width": 447.84116301831943,
      "height": 30.77591649699412,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bBu",
      "roundness": null,
      "seed": 1061196995,
      "version": 539,
      "versionNonce": 530246075,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1776160868478,
      "link": null,
      "locked": false,
      "text": "XNAT (in TRE) pulls the corresponding imaging data into a\ndedicated project where images can be enriched.",
      "fontSize": 12.310366598797648,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "XNAT (in TRE) pulls the corresponding imaging data into a dedicated project where images can be enriched.",
      "autoResize": false,
      "lineHeight": 1.25
    },
