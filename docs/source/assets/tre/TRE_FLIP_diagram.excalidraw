    {
      "id": "lqzL9EgGX55-yN1RY0J9W",
      "type": "text",
      "x": 259.75631986156026,
      "y": 1300.1291551396387,
      "width": 363.73699951171875,
      "height": 19.234947810621325,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
