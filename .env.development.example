# =============================================================================
# FLIP Environment Variables — Development Example
# =============================================================================
# Copy to .env.development and fill in the placeholders for local development.
# This file uses dummy/safe defaults ONLY. Never commit real secrets here.
#
# Quick-start:
#   1. cp .env.development.example .env.development
#   2. make generate-trust-api-keys
#   3. make generate-internal-service-key
#   4. make generate-trust-internal-service-keys
#   5. make create-networks && make up
#
# For staging/production, copy to .env.stag / .env.production instead.
# Variables marked "stag/prod only" are not needed for local development.
# =============================================================================

# ── AWS Profile ──────────────────────────────────────────────────────────
# Recommended: set this to `dev` and add a matching `[profile dev]` alias to
# ~/.aws/config (see deploy/providers/AWS/dev/README.md). If you keep a
# different naming convention, also set DEV_AWS_PROFILE here so the dev stack
# Makefile's guard recognises it (and STAG_AWS_PROFILE / PROD_AWS_PROFILE if
# you want its prod/stag refusal checks to recognise yours too).
AWS_PROFILE=<your-aws-profile-name>

# ── User / Group IDs ─────────────────────────────────────────────────────
# Docker container file permissions: bind-mounts inside containers use the
# same UID/GID as the host user, avoiding permission-denied errors.
UID=$(shell id -u)
GID=$(shell id -g)
UNAME=${USER}

# ── Central Hub Hostnames & Ports ─────────────────────────────────────────
UI_PORT=443
API_PORT=8080
DB_PORT=5432
UI_HOST=flip-ui
DB_HOST=flip-db
API_HOST=flip-api

# ── Central Hub Database Credentials ──────────────────────────────────────
# In production, the DB password lives in AWS Secrets Manager and the
# POSTGRES_PASSWORD here is unused (the Secrets Manager value takes precedence).
POSTGRES_USER=local_user
POSTGRES_PASSWORD=<your-postgres-password>
POSTGRES_DB=centralhub

# stag/prod only: Secrets Manager ARN that stores the RDS master password.
# The API reads it at startup if POSTGRES_SECRET_ARN is set.
# POSTGRES_SECRET_ARN=arn:aws:secretsmanager:<region>:<account>:secret:<id>

# stag/prod only: RDS master password for Terraform to bootstrap the database.
# Not needed for local development (Docker Compose uses POSTGRES_PASSWORD above).
# DB_PASSWORD=<your-rds-master-password>

# ── Trust Service Ports ───────────────────────────────────────────────────
# DICOM port for Orthanc PACS server
PACS_DICOM_PORT=4242
# Orthanc web UI ports (one per trust)
PACS_UI_PORT_TRUST_1=8042
PACS_UI_PORT_TRUST_2=8044

# OMOP database ports. Used by the host to populate mock data — normal
# cohort queries go through the trust services (trust-api → data-access-api),
# so these ports are not needed at query time.
OMOP_DB_PORT_TRUST_1=5434
OMOP_DB_PORT_TRUST_2=5436

# Trust API ports (exposed on localhost for testing)
IMAGING_API_PORT=8001
DATA_ACCESS_API_PORT=8010
TRUST_API_PORT=8020
PGADMIN_PORT=5050

# ── Trust Docker Network URLs ─────────────────────────────────────────────
# Internal Docker-network URLs used by trust services to call each other.
# These resolve to container names on the trust Docker network.
DATA_ACCESS_API_URL=http://data-access-api:8000
IMAGING_API_URL=http://imaging-api:8000
# XNAT (neuroimaging) service
XNAT_URL=http://xnat-web:8080
XNAT_DATABASE_URL=postgresql+asyncpg://xnat:xnat@xnat-db:5432/xnat

# ── Central Hub API URL ──────────────────────────────────────────────────
# Base URL of the flip-api backend, including /api. Drives both the UI
# (via window.AWS_BASE_URL from generate-window-js.sh) and trust → hub
# polling traffic. In local dev this is localhost; in stag/prod it is
# the CloudFront distribution URL.
CENTRAL_HUB_API_URL=http://localhost:8080/api

# Internal Docker-network URL used by fl-server on the Central Hub to call
# flip-api directly. MUST resolve on the hub's docker network and MUST NOT
# point at a public URL — the CloudFront distribution fronting flip-api
# whitelists only Authorization/Content-Type/Origin and strips
# X-Internal-Service-Key at the edge, which would make every internal
# fl-server → flip-api call fail auth.
FLIP_API_INTERNAL_URL=http://flip-api:8000/api

# ── Polling ───────────────────────────────────────────────────────────────
# Interval (seconds) at which the trust-api polls the Central Hub for new
# tasks. Lower values mean faster task pickup but more API calls.
POLL_INTERVAL_SECONDS=5

# ── UI Variables ──────────────────────────────────────────────────────────
# NODE_ENV=development here drives Vite's local dev server — `make up`
# runs the UI container which reads this value and serves a dev bundle
# with HMR + dev-only Vue warnings. For deploys, omit NODE_ENV from
# .env.stag / .env.production entirely: `make deploy-ui` exports this
# file into `npm ci && vite build`, and setting NODE_ENV=production
# here would make npm skip devDependencies (Vite included). Vite's
# build command sets NODE_ENV internally for the bundle output.
NODE_ENV=development

# When true, the UI expects the API to run on localhost without TLS.
# When false (stag/prod), the UI expects HTTPS via CloudFront.
VITE_LOCAL=false

# Comma-separated list of filenames that should NOT appear in the model
# file upload UI. These are framework internals (training scripts, event
# handlers, validators) that users should never select for upload.
BLACKLISTED_MODEL_FILES=flip.py,server_app.py

# ── Trust Credentials ────────────────────────────────────────────────────

# --- Orthanc (DICOM / PACS) ---
ORTHANC_USERNAME=<your-orthanc-username>
ORTHANC_PASSWORD=<your-orthanc-password>
# Host path for each Orthanc database bind mount. Can be:
#   - An absolute path like /opt/flip/orthanc-storage
#   - A repo-relative path starting with ./ (resolved by compose against trust/)
ORTHANC_STORAGE_DIR_TRUST_1=./orthanc/orthanc-storage
ORTHANC_STORAGE_DIR_TRUST_2=./orthanc/orthanc-storage-2

# --- OMOP Database ---
# OMOP admin credentials (used by the omop-db service itself)
OMOP_DB_SERVICE_NAME=omop-db
OMOP_POSTGRES_USER=postgres
OMOP_POSTGRES_PASSWORD=<your-omop-postgres-password>
OMOP_POSTGRES_DB=trustomopdb
OMOP_DB_TAG=latest

# OMOP read-only user credentials (used by data-access-api for cohort queries).
# This user should have SELECT-only permissions on the OMOP schema.
DATA_ACCESS_POSTGRES_USER=data_analyst_reader
DATA_ACCESS_POSTGRES_PASSWORD=<your-data-analyst-reader-password>

# --- PGAdmin (optional DB management UI) ---
PGADMIN_EMAIL=<your-email-for-pgadmin-login>
PGADMIN_PASSWORD=<your-pgadmin-password>

# --- XNAT (Neuroimaging Platform) ---
XNAT_PORT_TRUST_1=8104
XNAT_PORT_TRUST_2=8106
XNAT_ADMIN_USER=<your-xnat-admin-username>
# Bootstrap password shipped by the upstream XNAT image. Used only for the
# first login, after which the admin password is rotated to XNAT_ADMIN_PASSWORD.
XNAT_ADMIN_INITIAL_PASSWORD=admin
XNAT_ADMIN_PASSWORD=<your-xnat-admin-password>
# Service account created during XNAT setup. Used by imaging-api for API calls.
# Credentials must match the XNAT service account configured in the XNAT UI.
XNAT_SERVICE_USER=<your-xnat-service-account-username>
XNAT_SERVICE_PASSWORD=<your-xnat-service-account-password>

# ── PACS / ALB / NLB ──────────────────────────────────────────────────────
# Local PACS index used for Orthanc configuration
PACS_ID=1
# stag/prod only: ALB and NLB subdomains for the deployment.
# In development these are not used — containers communicate via Docker DNS.
# ALB_SUBDOMAIN=<your-alb-subdomain>   # e.g., "my-flip-app" if ALB is my-flip-app.eu-west-2.elb.amazonaws.com
# NLB_SUBDOMAIN=<your-nlb-subdomain>

# ── Base Images Download Dirs ─────────────────────────────────────────────
# Directories where trust services store downloaded medical images.
# Absolute paths or repo-relative (via ./) for development.
BASE_IMAGES_DOWNLOAD_DIR_TRUST1=./data/Trust_1
BASE_IMAGES_DOWNLOAD_DIR_TRUST2=./data/Trust_2

# ── Federated Learning Configuration ──────────────────────────────────────
# Directory inside the FL container for admin/startup files
FL_ADMIN_DIRECTORY=/app/admin
# Ports for the FL API, server, and client containers on the Central Hub
FL_API_PORT=8000
FL_SERVER_PORT=8002

# GPU resources available to the FL client. Set to 0 if no GPU is available
# (CPU-only training). These values are reported to the FL server for
# resource-aware job scheduling.
NUM_AVAILABLE_GPUS=1
MEMORY_PER_GPU_IN_GIB=7

# Minimum number of FL clients that must be connected before the FL server
# starts a training round. Set higher for larger federations to ensure
# statistical quality. Default is 1 (start as soon as any client connects).
MIN_CLIENTS=1

# FL_PROVISIONED_DIR is derived from FL_BACKEND in deploy/fl_backend.mk
# (../flip-fl-base/workspace for nvflare, ../flip-fl-base-flower/certs for
# flower). It is only read by the development compose overlays. Override
# on the command line for a one-off: `make up FL_PROVISIONED_DIR=/tmp/ws`.

# Kit date for the FL provisioned workspace. Used in production to download
# the correct kit archive from S3 (s3://<bucket>/base-application/<backend>/<kit_date>/).
# FLARE_KIT_DATE is used when FL_BACKEND=nvflare; FLOWER_KIT_DATE when FL_BACKEND=flower.
FLARE_KIT_DATE=20260318
FLOWER_KIT_DATE=20260401

# ── Authentication & API Keys ─────────────────────────────────────────────
# HTTP header name for trust-to-hub API key authentication
TRUST_API_KEY_HEADER=Authorization

# Trust and internal service API keys
# Run these commands to populate (they write into .env.development):
#   make generate-trust-api-keys          — per-trust keys for trust → hub auth
#   make generate-internal-service-key    — internal key for fl-server → hub auth
#   make generate-trust-internal-service-keys — per-trust keys for trust-internal auth
TRUST_API_KEYS={"Trust_1": "<run-make-generate-trust-api-keys>", "Trust_2": "<run-make-generate-trust-api-keys>"}
TRUST_API_KEY_HASHES={"Trust_1": "<hash>", "Trust_2": "<hash>"}

# Internal service auth (fl-server on Central Hub → flip-api).
# The fl-server sends INTERNAL_SERVICE_KEY in the INTERNAL_SERVICE_KEY_HEADER.
# flip-api verifies against INTERNAL_SERVICE_KEY_HASH (SHA-256).
INTERNAL_SERVICE_KEY_HEADER=X-Internal-Service-Key
INTERNAL_SERVICE_KEY=<run-make-generate-internal-service-key>
INTERNAL_SERVICE_KEY_HASH=<sha256-of-internal-service-key>

# Trust-internal service auth (trust-api, imaging-api, fl-client → imaging-api, data-access-api).
# Per-trust JSON dict — each trust uses a distinct key. Distinct from the hub's
# INTERNAL_SERVICE_KEY: a leak in one trust never affects another, and the hub
# never sees these. Run `make generate-trust-internal-service-keys` to populate.
TRUST_INTERNAL_SERVICE_KEY_HEADER=X-Trust-Internal-Service-Key
TRUST_INTERNAL_SERVICE_KEYS={"Trust_1": "<run-make-generate-trust-internal-service-keys>", "Trust_2": "<run-make-generate-trust-internal-service-keys>"}

# AES-256 encryption key for trust → hub communication, base64-encoded.
# Must be a 32-byte (256-bit) key. Generate a new one for testing:
#   python3 -c "import base64, os; print(base64.b64encode(os.urandom(32)).decode())"
AES_KEY_BASE64=<your-base64-encoded-32-byte-aes-key-for-testing>

# ── Debug Ports ───────────────────────────────────────────────────────────
# Ports for remote debugging (debugpy). When DEBUG=true and the service is
# started via `make debug SERVICE=<name>`, debugpy listens on these ports.
TRUST_DEBUG_PORT_TRUST_1=5682
IMAGING_DEBUG_PORT_TRUST_1=5681
DATA_ACCESS_DEBUG_PORT_TRUST_1=5680
TRUST_DEBUG_PORT_TRUST_2=5685
IMAGING_DEBUG_PORT_TRUST_2=5684
DATA_ACCESS_DEBUG_PORT_TRUST_2=5683
# Enable debug mode (debugpy listeners) for all services.
# Set to false for normal operation, true to enable remote debugging.
DEBUG=false

# ── Observability ─────────────────────────────────────────────────────────
# Grafana + Loki stack for trust service logs and metrics
GRAFANA_ADMIN_PASSWORD=<your-grafana-admin-password>
GRAFANA_PORT_TRUST_1=3000
LOKI_PORT_TRUST_1=3100
GRAFANA_PORT_TRUST_2=3001
LOKI_PORT_TRUST_2=3101
# Log level for all trust services (DEBUG in development, INFO in staging/production)
TRUST_LOG_LEVEL=DEBUG
# Log level for the Central Hub flip-api logger. The Settings default is
# INFO so any unknown environment (prod, stag, any new deploy) emits at
# INFO and avoids leaking debug-level diagnostics. Local dev compose pins
# DEBUG via deploy/compose.development.yml. Set to WARNING or ERROR to
# tighten production output further.
LOG_LEVEL=DEBUG

# ── Docker Image Tags ─────────────────────────────────────────────────────
# Tag for flip-api and flip-ui images (defaults to "stag" in development
# compose; set to "develop" for the latest CI builds or a branch name for
# testing. In stag/prod, typically pinned to a specific release tag.)
DOCKER_TAG=stag
# Docker registry (GHCR) for FL images. The same tag is used for all FL
# images to ensure compatibility between server, client, and API.
DOCKER_REGISTRY=ghcr.io/londonaicentre/
DOCKER_FL_TAG=stag

# DOCKER_FL_API_NAME / DOCKER_FL_SERVER_NAME / DOCKER_FL_CLIENT_NAME are
# derived from FL_BACKEND in deploy/fl_backend.mk. Override here only if you
# need custom image names (e.g., flare-fl-api for NVFLARE, flower-fl-api for
# Flower). The defaults are:
#   - nvflare: flare-fl-api, flare-fl-server, flare-fl-client
#   - flower:  flower-fl-api, flower-fl-server, flower-fl-client
# DOCKER_FL_API_NAME=flare-fl-api
# DOCKER_FL_SERVER_NAME=flare-fl-server
# DOCKER_FL_CLIENT_NAME=flare-fl-client

# Federated Learning backend: "nvflare" (NVIDIA FLARE) or "flower" (Flower).
# Determines which FL images, provisioned workspace, and compose files are used.
FL_BACKEND=nvflare

# ── MFA Enforcement ───────────────────────────────────────────────────────
# Controls whether the API requires TOTP enrollment for all authenticated
# routes. Default is "true" (enforced) in production. In development, the
# compose file overrides this to "false" so you don't need to enrol a
# burner authenticator app. Do NOT set in stag/prod env files — the Pydantic
# Settings default (true) applies there.
# ENFORCE_MFA=false

# ── AWS Infrastructure (dev only) ────────────────────────────────────────
# stag/prod only: the S3 bucket for Terraform remote state.
# FLIP_TFSTATE_BUCKET_NAME=<your-s3-bucket-name>
# stag/prod only: VPC name for the deployment.
# VPC_NAME=<vpc-name>

# ── AWS SES ───────────────────────────────────────────────────────────────
# Email address verified with AWS SES for sending system emails (password
# resets, notifications). Must be verified in the SES console before use.
SES_VERIFIED_EMAIL=<your-email-verified-with-ses-for-sending-emails>

# ── AWS Cognito ───────────────────────────────────────────────────────────
AWS_REGION=<your-aws-region>           # e.g., "eu-west-2"
AWS_COGNITO_USER_POOL_ID=<your-cognito-user-pool-id>     # e.g., "eu-west-2_XXXXXXXXX"
AWS_COGNITO_APP_CLIENT_ID=<your-cognito-app-client-id>   # e.g., "XXXXXXXXXXXXXXXXXXXXXXXXXX"
AWS_SECRET_NAME=FLIP_API               # Secrets Manager secret name (same across envs)
AWS_SES_ADMIN_EMAIL_ADDRESS=${SES_VERIFIED_EMAIL}
AWS_SES_SENDER_EMAIL_ADDRESS=${SES_VERIFIED_EMAIL}
# Initial password for the admin user created on first login via Cognito.
ADMIN_USER_PASSWORD=<your-initial-password-for-admin-user-login>

# ── S3 Buckets ────────────────────────────────────────────────────────────
# stag/prod only: S3 bucket names. In development, LocalStack is used instead.
# FLIP_BUCKET_NAME=<your-s3-bucket-name>          # e.g., "flipdev"
# FLIP_ARTIFACTS_BUCKET_NAME=<your-s3-bucket-name> # e.g., "flipdev-artifacts"
# AICENTRE_BUCKET_NAME=<your-s3-bucket-name>       # e.g., "flipdev-aicentre"
# FLIP_UI_BUCKET_NAME=<your-s3-bucket-name>        # e.g., "flip-ui-dev"

# S3 paths used by the Central Hub for storing uploaded models, federated
# data, and FL application code. In development with LocalStack, these
# resolve to the localstack container.
UPLOADED_MODEL_FILES_BUCKET=s3://${FLIP_BUCKET_NAME}/model_files/uploaded
# FIXME: currently using the same bucket for scanned + unscanned model files.
# When a dedicated malware-scanning pipeline is added, split these.
SCANNED_MODEL_FILES_BUCKET=s3://${FLIP_BUCKET_NAME}/model_files/uploaded
# Staging area where FL clients upload federated training results (model
# weights, metrics) via pre-signed URLs. The FL server downloads from here,
# aggregates, and uploads the global model back.
UPLOADED_FEDERATED_DATA_BUCKET=s3://${FLIP_BUCKET_NAME}/uploaded_federated_data
# Base application code and configuration for the FL backend. Contains
# provisioned certs, training scripts, and client/server admin configs.
FL_APP_BASE_BUCKET=s3://${FLIP_BUCKET_NAME}/base-application/${FL_BACKEND}
# Destination bucket where the FL server writes the final trained model
# after aggregation. Users can download from here via the UI.
FL_APP_DESTINATION_BUCKET=s3://${FLIP_BUCKET_NAME}/app_destination_bucket

# ── FL Net Endpoints ──────────────────────────────────────────────────────
# Maps FL network IDs to internal API URLs for the FL API containers on the
# Central Hub. These are reachable from within the Docker network in all
# environments. For local dev and EC2/Docker Compose, use Docker container
# hostnames (flip-fl-api-net-1). For ECS Fargate (PR 2+), use Cloud Map
# FQDNs (flip-fl-api-net-1.flip.local).
#
# NOTE you must use double quotes for the JSON string to be parsed correctly
# by Python. Add one entry per FL network.
NET_ENDPOINTS={"net-1":"http://flip-fl-api-net-1:8000", "net-2":"http://flip-fl-api-net-2:8000"}

# ── Trust Names ───────────────────────────────────────────────────────────
# JSON list of trust names that will be seeded into the database. Acts as an
# allowlist: the Central Hub only accepts connections from trusts whose names
# appear here and have valid API keys in TRUST_API_KEYS.
TRUST_NAMES=["Trust_1", "Trust_2"]
