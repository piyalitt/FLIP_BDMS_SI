AWS_PROFILE=<your-aws-profile-name>
# User and Group IDs for running the containers with compatible permissions
UID=$(shell id -u)
GID=$(shell id -g)
UNAME=${USER}
# Ports for the central hub services
UI_PORT=443
API_PORT=8080
DB_PORT=5432
# Services hostnames
UI_HOST=flip-ui
DB_HOST=flip-db
API_HOST=flip-api
# Credentials for the central hub services
POSTGRES_USER=local_user
# in prod, POSTGRES_PASSWORD ignored and uses AWS Secrets Manager to store the password
POSTGRES_PASSWORD=<your-postgres-password>
POSTGRES_DB=centralhub
# Ports for the trust services
PACS_DICOM_PORT=4242
PACS_UI_PORT_TRUST_1=8042
PACS_UI_PORT_TRUST_2=8044
PACS_UI_PORT_LOCAL_TRUST=8046
# Need to specify ports for the OMOP database so that we can populate it with mock data from the host. Normally when
# running cohort queries the OMOP database will be accessed via the trust services, so ports won't be needed.
OMOP_DB_PORT_TRUST_1=5434
OMOP_DB_PORT_TRUST_2=5436
IMAGING_API_PORT=8001
DATA_ACCESS_API_PORT=8010
TRUST_API_PORT=8020
PGADMIN_PORT=5050
# UI variables
NODE_ENV=development
VITE_LOCAL=false
VITE_AWS_BASE_URL=http://localhost:8080/api
VITE_BLACKLISTED_MODEL_FILES=flip.py,server_app.py
# Credentials for the trust services
ORTHANC_USERNAME=admin
ORTHANC_PASSWORD=admin
ORTHANC_STORAGE_TRUST_1=orthanc-storage
ORTHANC_STORAGE_TRUST_2=orthanc-storage-2
# OMOP database credentials
# OMOP admin credentials
OMOP_DB_SERVICE_NAME=omop-db
OMOP_POSTGRES_USER=postgres
OMOP_POSTGRES_PASSWORD=<your-omop-postgres-password>
OMOP_POSTGRES_DB=trustomopdb
OMOP_DB_TAG=latest
# OMOP read-only user credentials
DATA_ACCESS_POSTGRES_USER=data_analyst_reader
DATA_ACCESS_POSTGRES_PASSWORD=<your-data-analyst-reader-password>
# Other credentials
PGADMIN_EMAIL=<your-email-for-pgadmin-login>
PGADMIN_PASSWORD=<your-pgadmin-password>
#
XNAT_PORT_TRUST_1=8104
XNAT_PORT_TRUST_2=8106
XNAT_PORT_LOCAL_TRUST=8108
XNAT_URL=http://xnat-web:8080
XNAT_DATABASE_URL=postgresql+asyncpg://xnat:xnat@xnat-db:5432/xnat
XNAT_ADMIN_USER=<your-xnat-admin-username>
XNAT_ADMIN_INITIAL_PASSWORD=admin
XNAT_ADMIN_PASSWORD=<your-xnat-admin-password>
XNAT_SERVICE_USER=<your-xnat-service-account-username>
XNAT_SERVICE_PASSWORD=<your-xnat-service-account-password>
DATA_ACCESS_API_URL=http://data-access-api:8000
IMAGING_API_URL=http://imaging-api:8000
# Local dev (same-host docker): use internal service name over HTTP
# Hybrid/staging (trust on local machine → AWS Central Hub): https://stag.flip.aicentre.co.uk
CENTRAL_HUB_API_URL=http://flip-api:8000/api
POLL_INTERVAL_SECONDS=5
PACS_ID=1
ALB_SUBDOMAIN=<your-alb-subdomain> # e.g., "my-flip-app" if your ALB is my-flip-app.eu-west-2.elb.amazonaws.com
NLB_SUBDOMAIN=<your-nlb-subdomain>
#
BASE_IMAGES_DOWNLOAD_DIR_TRUST1=./data/Trust_1
BASE_IMAGES_DOWNLOAD_DIR_TRUST2=./data/Trust_2
# Federated Learning configurations
FL_ADMIN_DIRECTORY=/app/admin
FL_API_PORT=8000
FL_SERVER_PORT=8002
# Path to NVFLARE provisioned workspace (from flip-fl-base)
# Contains certificates, fed_client.json, and other provisioned files per network
# NOTE: This is overridden by the Makefile to use an absolute path resolved relative to the repo
FL_PROVISIONED_DIR=../flip-fl-base/workspace
NUM_AVAILABLE_GPUS=1
MEMORY_PER_GPU_IN_GIB=7
MIN_CLIENTS=1
#
TRUST_API_KEY_HEADER=Authorization
# Trust and internal service API keys
# Run `make generate-trust-api-keys` and `make generate-internal-service-key` to populate.
TRUST_API_KEYS={"Trust_1": "<run-make-generate-trust-api-keys>", "Trust_2": "<run-make-generate-trust-api-keys>"}
TRUST_API_KEY_HASHES={"Trust_1": "<hash>", "Trust_2": "<hash>"}
# Internal service auth (fl-server on Central Hub → flip-api)
INTERNAL_SERVICE_KEY_HEADER=X-Internal-Service-Key
INTERNAL_SERVICE_KEY=<run-make-generate-internal-service-key>
INTERNAL_SERVICE_KEY_HASH=<sha256-of-internal-service-key>
AES_KEY_BASE64=<your-base64-encoded-32-byte-aes-key-for-testing>  # This should be a base64-encoded 32-byte key for AES-256 encryption (e.g., "c2VjdX...==")
#
TRUST_DEBUG_PORT_TRUST_1=5682
IMAGING_DEBUG_PORT_TRUST_1=5681
DATA_ACCESS_DEBUG_PORT_TRUST_1=5680
TRUST_DEBUG_PORT_TRUST_2=5685
IMAGING_DEBUG_PORT_TRUST_2=5684
DATA_ACCESS_DEBUG_PORT_TRUST_2=5683
DEBUG=false

# Observability stack configurations for both trust services - using Grafana and Loki for logs and metrics
GRAFANA_ADMIN_PASSWORD=<your-grafana-admin-password>
GRAFANA_PORT_TRUST_1=3000
LOKI_PORT_TRUST_1=3100
GRAFANA_PORT_TRUST_2=3001
LOKI_PORT_TRUST_2=3101
# Log level for all trust services (DEBUG in development, INFO in staging/production)
TRUST_LOG_LEVEL=DEBUG

# DOCKER_TAG for UI and API services
DOCKER_TAG=stag
# Docker tag for FL API, server and client images from https://github.com/londonaicentre/flip-fl-base/packages
# NOTE the same tag is used for all Docker images to ensure compatibility
DOCKER_REGISTRY=ghcr.io/londonaicentre/
DOCKER_FL_TAG=stag
DOCKER_FL_API_NAME=flare-fl-api
DOCKER_FL_SERVER_NAME=flare-fl-server
DOCKER_FL_CLIENT_NAME=flare-fl-client
# Supported values: flower | nvflare
FL_BACKEND=nvflare

SES_VERIFIED_EMAIL=<your-email-verified-with-ses-for-sending-emails>

# AWS_PROFILE is not used in production - EC2 instance uses IAM role
AWS_REGION=<your-aws-region> # e.g., "eu-west-2"
AWS_COGNITO_USER_POOL_ID=<your-cognito-user-pool-id>  # e.g., "eu-west-2_XXXXXXXXX"
AWS_COGNITO_APP_CLIENT_ID=<your-cognito-app-client-id>  # e.g., "XXXXXXXXXXXXXXXXXXXXXXXXXX"
AWS_SECRET_NAME=FLIP_API
AWS_SES_ADMIN_EMAIL_ADDRESS=${SES_VERIFIED_EMAIL}
AWS_SES_SENDER_EMAIL_ADDRESS=${SES_VERIFIED_EMAIL}
ADMIN_USER_PASSWORD=<your-initial-password-for-admin-user-login>

FLIP_TFSTATE_BUCKET_NAME=<your-s3-bucket-name-for-terraform-state> # e.g., "flip-tf-state-dev"
FLIP_BUCKET_NAME=<your-s3-bucket-name-for-flip-assets> # e.g., "flipdev"
FLIP_ARTIFACTS_BUCKET_NAME=<your-s3-bucket-name-for-flip-artifacts> # e.g., "flipdev-artifacts"
AICENTRE_BUCKET_NAME=<your-s3-bucket-name-for-aicentre-assets> # e.g., "flipdev-aicentre"
UPLOADED_MODEL_FILES_BUCKET=s3://${FLIP_BUCKET_NAME}/model_files/uploaded
# FIXME scan the uploaded files - currently using the same bucket
SCANNED_MODEL_FILES_BUCKET=s3://${FLIP_BUCKET_NAME}/model_files/uploaded
UPLOADED_FEDERATED_DATA_BUCKET=s3://${FLIP_BUCKET_NAME}/uploaded_federated_data
FL_APP_BASE_BUCKET=s3://${FLIP_BUCKET_NAME}/base-application/${FL_BACKEND}
FL_APP_DESTINATION_BUCKET=s3://${FLIP_BUCKET_NAME}/app_destination_bucket

# Net endpoints are reachable by the Central Hub from within the Docker network in all environments, so we can use the internal hostnames and ports.
# NOTE you must use double quotes for the JSON string to be parsed correctly by Python
NET_ENDPOINTS={"net-1":"http://flip-fl-api-net-1:8000", "net-2":"http://flip-fl-api-net-2:8000"}

# Trust names that will be seeded into the database (acts as an allowlist for polling trusts)
TRUST_NAMES=["Trust_1", "Trust_2"]
